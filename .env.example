APP_ENV=local

# Database
# SQLite (default)
APP_DB_DRIVER=sqlite3
APP_DB_NAME=./skinprice.db
APP_DB_DEBUG=false
APP_DB_MAX_OPEN_CONNS=10
APP_DB_MAX_IDLE_CONNS=10
APP_DB_CONN_MAX_LIFE_TIME=300

# Postgres example:
# APP_DB_DRIVER=pgx
# APP_DB_HOST=127.0.0.1
# APP_DB_PORT=5432
# APP_DB_NAME=skinprice
# APP_DB_USER=skinprice
# APP_DB_PASSWORD=skinprice
# APP_DB_SSLMODE=disable

STEAM_BASE_URL=https://steamcommunity.com/market
LISSKINS_BASE_URL=https://api.lis-skins.com/v1

HTTP_TIMEOUT_SECONDS=10
CACHE_TTL_SECONDS=300

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_TO_FILE=true
# LOG_FILE_PATH=./logs/skinprice.log
LOG_MAX_SIZE_MB=20
LOG_MAX_BACKUPS=5
LOG_MAX_AGE_DAYS=14
LOG_COMPRESS=true
